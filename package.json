{
  "name": "waypoint-planner",
  "version": "1.2.0",
  "description": "DJI Drone Waypoint Flight Planner with Premium Features",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:electron && npm run build:vite",
    "build:electron": "tsc -p tsconfig.node.json",
    "build:vite": "vite build",
    "build:app": "npm run build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "node scripts/dev.js",
    "electron:pack": "electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "generate-icons": "node scripts/generate-icons.js"
  },
  "keywords": [
    "drone",
    "waypoint",
    "dji",
    "flight-plan",
    "photogrammetry"
  ],
  "author": "KPISTOLAS",
  "license": "MIT",
  "homepage": "https://github.com/KPISTOLAS/waypoint-planner",
  "repository": {
    "type": "git",
    "url": "https://github.com/KPISTOLAS/waypoint-planner.git"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^35.7.5",
    "electron-builder": "^24.9.1",
    "sharp": "^0.34.5",
    "typescript": "^5.3.3",
    "vite": "^6.2.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@react-three/drei": "^9.92.7",
    "@react-three/fiber": "^8.15.11",
    "@types/leaflet-draw": "^1.0.13",
    "jotai": "^2.6.4",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "leaflet-draw": "^1.0.4",
    "lucide-react": "^0.303.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.21.1",
    "three": "^0.159.0"
  },
  "build": {
    "appId": "com.waypointplanner.app",
    "productName": "Waypoint Planner",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "fileAssociations": [],
    "extraMetadata": {},
    "asar": true,
    "asarUnpack": [],
    "compression": "maximum",
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-Portable.${ext}"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
